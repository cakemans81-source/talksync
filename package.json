{
  "name": "talksync",
  "version": "0.1.0",
  "description": "Real-time speech-to-speech translation for Discord & Teams",
  "author": "TalkSync",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:web": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -n NEXT,ELECTRON -c cyan,yellow \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:compile && electron .\"",
    "electron:build": "cross-env ELECTRON_BUILD=true next build && npm run electron:compile && electron-builder",
    "electron:build:win": "cross-env ELECTRON_BUILD=true next build && npm run electron:compile && electron-builder --win",
    "build:app": "cross-env ELECTRON_BUILD=true next build && npm run electron:compile",
    "package": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish never",
    "package:all": "npm run build:app && npm run package",
    "deploy": "git add -A && git commit -m \"deploy: $(date '+%Y-%m-%d %H:%M')\" && git push origin main"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@ricky0123/vad-web": "^0.0.30",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "next": "16.2.0",
    "next-intl": "^4.8.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.3.4",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "npmRebuild": false,
    "appId": "com.talksync.app",
    "productName": "TalkSync",
    "copyright": "Copyright © 2025 TalkSync",
    "asar": true,
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "electron-dist/**/*",
      "package.json",
      "!**/.env",
      "!**/.env.*",
      "!**/*.local",
      "!**/node_modules/**",
      "!**/src/**",
      "!**/electron/**"
    ],
    "protocols": [
      {
        "name": "TalkSync OAuth",
        "schemes": [
          "talksync"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "TalkSync-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TalkSync",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
